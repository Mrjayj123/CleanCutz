ackground":4294440951,"raisedBackground":4294440951,"additiveBackground":562530183,"textPrimary":4280295456,"textSecondary":4283716692,"invertedBackground":4283716692,"overlayBackground":3424657440},"darkThemeColorPalette":{"baseBackground":4279176975,"raisedBackground":4280295456,"additiveBackground":730302343,"textPrimary":4293783021,"textSecondary":4291085508,"invertedBackground":4289111718,"overlayBackground":3424657440},"enableColorSampledText":true}},"viewCountType":"VIEW_COUNT_FACTOID_TYPE_TOTAL_VIEWS"}},{"factoidRenderer":{"value":{"simpleText":"26 Apr"},"label":{"simpleText":"2026"},"accessibilityText":"26 Apr 2026","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294440951,"raisedBackground":4294440951,"additiveBackground":562530183,"textPrimary":4280295456,"textSecondary":4283716692,"invertedBackground":4283716692,"overlayBackground":3424657440},"darkThemeColorPalette":{"baseBackground":4279176975,"raisedBackground":4280295456,"additiveBackground":730302343,"textPrimary":4293783021,"textSecondary":4291085508,"invertedBackground":4289111718,"overlayBackground":3424657440},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBUQ040EGAYiEwiE8ceU0JuVAxW0yE8IHdFjEcrKAQTIf8pn","commandMetadata":{"webCommandMetadata":{"url":"/@itsBellaKaymusic","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCODXz1YqLYhYS8T6thmY61Q","canonicalBaseUrl":"/@itsBellaKaymusic"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/vsMQrBbwO1Ng5F5nuQnSecDxhHSDh8yss6Ij_rwOBalwsI8cPxfcP4QPQyhE67039iaa-miBnQ=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"Promise? out now! \nhttps://bellakay.lnk.to/promise\n\nsee me live! \nhttps://bellakay.lnk.to/live \n\njoin my email list ;) \nhttps://drop.cobrand.com/d/BellaKay/S...\n\nCredits:\nShot by Katia Temkin @katiatemkin\nMixed Media Edit by Leesa Allmond @leesology\nLyric Animation by Alex Siegel @huhalex\n\nLyrics: \nthink i’d let you ruin me forever \nlaughing like a child with you crooked grin \ni’d tell you how i feel if i was clever \nmy interests all consist of \nif your if your if your \ninterested \n\ni should probably just leave it alone \ncause i know that we’re supposed to be friends \nwe’re friends \nwe’re friends but \n\noh i want you \nbut I’ll never tell ya \ncause if I tell you,\nyou could say i’m not \nthe one you want and i\ni couldn’t handle that \nso if i tell you\nthen promise me i can take it back  \ncan you promise that \ncan you promise that? \n\ndo you know what it’s like \nto feel this fucking shy \nlet me paint a picture for you\nyour voice keeps me up at night\ndo you know how it feels\npretend it’s no big deal\nwhen I’m looking up at you\ni make you laugh \nand oh god it feels like \n\nyou only left about a minute ago \nbut i already need to see you again\nagain \nagain \nagain like \n\noh i want you \nbut I’ll never tell ya \ncause if i tell you,\nyou could say i’m not \nthe one you want and i \ni couldn’t handle that \nso if i tell you\nthen promise me i can take it back  \ncan you promise that?\ncan you promise that?\nyeah if i tell you than promise me i can take it back \ncan you promise that?\n\nwish i could tell ya \ni think about you \nall the time \ni like your hair \ni like the way its \nin your stupid eyes \nwish i could tell ya \nyou’re with me \neverywhere i go \nyou’re in the rain\nyou’re in my drink \nyou’re in my cortisol\nwish i could tell ya \ni think about you \nall the time\ni’m scared to death that i’ll be wishing \nfor you for the rest of my life \n\ni want you \nBut i’ll never tell ya \ncause if i tell you,\nyou could say i’m not \nthe one you